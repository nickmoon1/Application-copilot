generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Application {
  id         String   @id @default(cuid())
  company    String
  role       String
  location   String
  source     String
  jobUrl     String
  matchScore Int
  notes      String
  prNumber   Int      @unique
  prUrl      String
  branch     String
  folder     String   @default("")
  status     String   @default("PENDING_REVIEW")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
